{
	"$schema": "vscode://schemas/color-theme",
	"name": "Abstract",
	"include": "./light_modern.json",
	"colors": {
		"focusBorder": "#5b6dc4",
		"foreground": "#1a1c20",
		"descriptionForeground": "#868b95",
		"errorForeground": "#b4332f",
		"selection.background": "#5b6dc43d",

		"textLink.foreground": "#5b6dc4",
